# HILO Node — environment template
# Copy this file to .env.node-a (or .env.node-b) and fill in your own values.
# Never commit your filled-in env file — it is git-ignored.

# Node identity
NODE_ID=node-a
NODE_NAME=HILO Node A

# Public base URL for this node's API (used for peer-to-peer data_url)
# With Cloudflare Tunnel: NODE_BASE_URL=https://node-a.hilosemantics.com
# Local-only development: NODE_BASE_URL=http://host.docker.internal:8000
NODE_BASE_URL=https://your-node-url.example.com

# Security — generate a random secret, e.g.: openssl rand -hex 32
INTERNAL_KEY=generate-a-random-secret-here

# GraphDB
GRAPHDB_REPO=hilo

# Ports exposed on your machine
GRAPHDB_PORT=7200
RABBITMQ_PORT=5672
RABBITMQ_MGMT_PORT=15672
API_PORT=8000
UI_PORT=3000

# AI features (optional)
# Required for the Ask AI mode in Data Explorer.
# Leave empty to disable Ask AI — the node starts normally without it.
ANTHROPIC_API_KEY=your-anthropic-api-key-here
